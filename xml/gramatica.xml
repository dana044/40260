<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE programa "gramatica.dtd"

<programa>
    <configuracion>
        <archivo>Proyecto_Restaurante.pdf</archivo> 
        <formato>Color</formato>                   
        <copias>2</copias>                         
    </configuracion>

    <proceso>
        <accion>
            <condicion sensor="papel" valor="SI">
                <accion><vista_previa/></accion> 
                <accion><imprimir/></accion>     
            </condicion>
        </accion>

        <accion>
            <condicion sensor="papel" valor="NO">
                <accion><cancelar/></accion>          
                <accion><mostrar_mensaje>Cancelado</mostrar_mensaje></accion> 
            </condicion>
        </accion>
    </proceso>
</programa>